# Copy this file to backend/.env and replace placeholder values as needed.

APP_NAME=FastAPI Auth System
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postiz
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postiz
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postiz_test

ACCESS_TOKEN_SECRET_KEY=change-me
REFRESH_TOKEN_SECRET_KEY=change-me-too
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
FACEBOOK_CONFIG_ID=
FACEBOOK_OAUTH_SCOPES=public_profile
FACEBOOK_API_VERSION=v22.0
FACEBOOK_STATE_EXPIRE_MINUTES=10

N8N_API_KEY=

POST_UPLOAD_DIR=uploads/posts
POST_MEDIA_URL_PREFIX=/media/posts
